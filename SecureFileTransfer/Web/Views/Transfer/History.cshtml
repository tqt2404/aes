@using SecureFileTransfer.Web.Controllers
@model List<TransferLogViewModel>

@{
    ViewData["Title"] = "Lịch Sử Giao Dịch";
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom">
            <div class="card-header">
                <h5><i class="bi bi-clock-history"></i> Lịch Sử Giao Dịch Truyền Tệp</h5>
            </div>
            <div class="card-body">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-info text-center">
                        <i class="bi bi-info-circle"></i>
                        <strong>Chưa có lịch sử giao dịch.</strong><br>
                        <small>Lịch sử sẽ được hiển thị khi bạn gửi hoặc nhận file.</small>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th><i class="bi bi-file-earmark"></i> Tên File</th>
                                    <th><i class="bi bi-hdd"></i> Kích Thước</th>
                                    <th><i class="bi bi-arrow-right"></i> Từ IP</th>
                                    <th><i class="bi bi-arrow-left"></i> Đến IP</th>
                                    <th><i class="bi bi-info-circle"></i> Trạng Thái</th>
                                    <th><i class="bi bi-calendar"></i> Thời Gian</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@log.FileName</strong>
                                        </td>
                                        <td>
                                            <small class="text-muted">@log.FileSizeFormatted</small>
                                        </td>
                                        <td>
                                            <code>@log.SenderIp</code>
                                        </td>
                                        <td>
                                            <code>@log.ReceiverIp</code>
                                        </td>
                                        <td>
                                            @if (log.Status.Contains("Sent"))
                                            {
                                                <span class="badge badge-sent">
                                                    <i class="bi bi-arrow-up"></i> Đã Gửi
                                                </span>
                                            }
                                            else if (log.Status.Contains("Received"))
                                            {
                                                <span class="badge badge-received">
                                                    <i class="bi bi-arrow-down"></i> Đã Nhận
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-error">
                                                    <i class="bi bi-exclamation-triangle"></i> Lỗi
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <small class="text-muted">@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</small>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <div class="row text-center">
                            <div class="col-md-3">
                                <small class="text-muted d-block">Tổng Giao Dịch</small>
                                <h5>@Model.Count</h5>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Dung Lượng Gửi</small>
                                <h5>@((long)Model.Where(x => x.Status.Contains("Sent")).Sum(x => x.FileSize)).ToString("N0") B</h5>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Dung Lượng Nhận</small>
                                <h5>@((long)Model.Where(x => x.Status.Contains("Received")).Sum(x => x.FileSize)).ToString("N0") B</h5>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Tổng Dung Lượng</small>
                                <h5>@FormatBytes((long)Model.Sum(x => x.FileSize))</h5>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@{
    string FormatBytes(long bytes)
    {
        if (bytes == 0) return "0 B";
        const long k = 1024;
        string[] sizes = { "B", "KB", "MB", "GB" };
        int order = (int)Math.Floor(Math.Log(bytes, k));
        return $"{bytes / Math.Pow(k, order):0.##} {sizes[order]}";
    }
}

<script>
    // Auto-refresh every 5 seconds
    setTimeout(() => {
        location.reload();
    }, 5000);
</script>
